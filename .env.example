# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Power Blackout Predictor"
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/blackout_predictor
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/blackout_predictor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Weather API ───────────────────────────────────────────────────────────────
# Free tier at https://openweathermap.org/api — 60 calls/min, global coverage
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ── SMS Gateway (internal microservice) ──────────────────────────────────────
SMS_GATEWAY_URL=http://localhost:8001
SMS_GATEWAY_API_KEY=your-internal-sms-gateway-key

# ── ML Engine ─────────────────────────────────────────────────────────────────
ML_ENGINE_URL=http://localhost:8002

# ── Jasmin SMPP core ─────────────────────────────────────────────────────────
# Jasmin is the SMPP broker that sits between this app and any telecom operator.
# It works with ANY operator worldwide — set SMPP_HOST to your aggregator's endpoint.
JASMIN_HOST=localhost
JASMIN_HTTP_PORT=8080
JASMIN_CLI_PORT=8990
JASMIN_USERNAME=jcliadmin
JASMIN_PASSWORD=jclipwd
JASMIN_SENDER_ID=BLACKOUT
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── SMPP connector — primary aggregator ──────────────────────────────────────
# Use any global SMS aggregator (Sinch, Infobip, Vonage, Africa's Talking SMPP,
# Twilio SMPP, or a direct operator SMPP endpoint).
# The connector ID set here becomes JASMIN_CONNECTOR_DEFAULT in the gateway.
SMPP_HOST=smpp.your-aggregator.com
SMPP_PORT=2775
SMPP_USERNAME=your-smpp-username
SMPP_PASSWORD=your-smpp-password
SMPP_OPERATOR_NAME=Primary Aggregator

# ── SMPP connector — per-country overrides (optional) ────────────────────────
# If your aggregator gives you different connector IDs per country, set them here.
# The gateway maps country code → JASMIN_CONNECTOR_{CC} env var.
# Example: JASMIN_CONNECTOR_RW=rw_connector
#          JASMIN_CONNECTOR_KE=ke_connector
# Leave blank to use the default connector for all countries.
JASMIN_CONNECTOR_DEFAULT=default
# JASMIN_CONNECTOR_RW=default
# JASMIN_CONNECTOR_KE=default
# JASMIN_CONNECTOR_NG=default
# JASMIN_CONNECTOR_GH=default
# JASMIN_CONNECTOR_ZA=default
# JASMIN_CONNECTOR_IN=default

# ── USSD ──────────────────────────────────────────────────────────────────────
# Short code digits (the *384# part)
USSD_SHORT_CODE=384
# HMAC secret from Africa's Talking or your USSD aggregator (leave blank to skip)
USSD_AT_SECRET=

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_pem().decode()); print('PUBLIC:', v.public_key)"
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_EMAIL=mailto:admin@blackoutpredictor.com

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────────
# https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=blackout_predictor_verify

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/v1/telegram/webhook

# ── SMTP Email ────────────────────────────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, AWS SES, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=alerts@blackoutpredictor.com
APP_URL=https://yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
