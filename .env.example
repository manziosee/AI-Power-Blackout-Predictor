# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Power Blackout Predictor"
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/blackout_predictor
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/blackout_predictor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Weather API ───────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ── SMS Gateway ───────────────────────────────────────────────────────────────
SMS_GATEWAY_URL=http://localhost:8001
SMS_GATEWAY_API_KEY=your-internal-sms-api-key

# ── Jasmin SMPP ───────────────────────────────────────────────────────────────
JASMIN_HOST=localhost
JASMIN_HTTP_PORT=8080
JASMIN_CLI_PORT=8990
JASMIN_USERNAME=jcliadmin
JASMIN_PASSWORD=jclipwd
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── SMPP Connectors ───────────────────────────────────────────────────────────
MTN_RW_SMPP_HOST=smpp.mtn.co.rw
MTN_RW_SMPP_PORT=2775
MTN_RW_SMPP_USERNAME=your-username
MTN_RW_SMPP_PASSWORD=your-password
MTN_RW_SMPP_SYSTEM_TYPE=

AIRTEL_RW_SMPP_HOST=smpp.airtel.rw
AIRTEL_RW_SMPP_PORT=2775
AIRTEL_RW_SMPP_USERNAME=your-username
AIRTEL_RW_SMPP_PASSWORD=your-password

# Fallback aggregator (used for countries without direct SMPP)
FALLBACK_SMPP_HOST=smpp.aggregator.com
FALLBACK_SMPP_PORT=2775
FALLBACK_SMPP_USERNAME=your-username
FALLBACK_SMPP_PASSWORD=your-password

# ── Mapbox (Frontend) ─────────────────────────────────────────────────────────
VITE_MAPBOX_TOKEN=your-mapbox-public-token

# ── Frontend API URL ──────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print('PRIVATE:', v.private_pem().decode()); print('PUBLIC:', v.public_key)"
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_CLAIMS_EMAIL=mailto:admin@blackoutpredictor.com
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────────
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=blackout_predictor_verify

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram, get token
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/v1/telegram/webhook

# ── SMTP Email ────────────────────────────────────────────────────────────────
# Works with Gmail, SendGrid, Mailgun, AWS SES, or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=alerts@blackoutpredictor.com
APP_URL=https://yourdomain.com

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
